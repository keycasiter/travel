page {
  background: #f7f2e8;
  color: #22322d;
  font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
}

button {
  border-radius: 8rpx;
}

.page {
  min-height: 100vh;
  box-sizing: border-box;
  padding: 40rpx 32rpx 160rpx;
}

.page-title {
  font-size: 44rpx;
  font-weight: 700;
  line-height: 1.2;
}

.page-subtitle {
  margin-top: 12rpx;
  color: #64716b;
  font-size: 26rpx;
  line-height: 1.5;
}
