page {
  --travel-paper: #f7f1e6;
  --travel-paper-deep: #eee4d2;
  --travel-ink: #22322d;
  --travel-muted: #68736d;
  --travel-jade: #2d6b5d;
  --travel-jade-deep: #1f564c;
  --travel-cinnabar: #a84a34;
  --travel-gold: #a47b42;
  --travel-line: rgba(34, 50, 45, 0.13);
  --travel-card: rgba(255, 253, 247, 0.9);
  background: #f7f1e6;
  background: var(--travel-paper);
  color: #22322d;
  color: var(--travel-ink);
  font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
}

button {
  border-radius: 8rpx;
}

button::after {
  border: 0;
}

.page {
  min-height: 100vh;
  box-sizing: border-box;
  padding: 64rpx 28rpx 168rpx;
}

.app-paper-bg {
  background:
    radial-gradient(circle at 20% 8%, rgba(255, 253, 247, 0.92), rgba(255, 253, 247, 0) 36%),
    linear-gradient(145deg, #fbf7ee 0%, #f4ebdc 48%, #efe3d0 100%);
}

.app-paper-bg::before {
  content: "";
  position: fixed;
  top: -80rpx;
  left: -120rpx;
  right: -120rpx;
  bottom: -80rpx;
  z-index: -1;
  pointer-events: none;
  opacity: 0.36;
  background-image:
    linear-gradient(90deg, rgba(68, 91, 82, 0.05) 1rpx, transparent 1rpx),
    linear-gradient(0deg, rgba(68, 91, 82, 0.04) 1rpx, transparent 1rpx);
  background-size: 42rpx 42rpx, 42rpx 42rpx;
}

.page-title {
  color: #22322d;
  color: var(--travel-ink);
  font-family: "STKaiti", "Kaiti SC", serif;
  font-size: 48rpx;
  font-weight: 700;
  line-height: 1.18;
  letter-spacing: 0;
}

.page-subtitle {
  margin-top: 12rpx;
  color: var(--travel-muted);
  font-size: 25rpx;
  line-height: 1.5;
}

.ink-card {
  position: relative;
  box-sizing: border-box;
  border: 1rpx solid rgba(69, 85, 74, 0.16);
  border-radius: 20rpx;
  background:
    linear-gradient(145deg, rgba(255, 253, 247, 0.96), rgba(246, 238, 224, 0.88));
  box-shadow:
    0 18rpx 52rpx rgba(41, 55, 48, 0.12),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.78);
}

.seal-badge {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-width: 34rpx;
  height: 42rpx;
  box-sizing: border-box;
  padding: 0 8rpx;
  border-radius: 8rpx;
  background: #a84a34;
  background: var(--travel-cinnabar);
  color: #fff8ec;
  font-size: 20rpx;
  font-weight: 700;
  line-height: 42rpx;
}

.primary-cta,
.secondary-cta {
  height: 86rpx;
  line-height: 86rpx;
  padding: 0 24rpx;
  border-radius: 12rpx;
  font-size: 28rpx;
  font-weight: 700;
}

.primary-cta {
  background: #2d6b5d;
  background: linear-gradient(135deg, var(--travel-jade), var(--travel-jade-deep));
  color: #fffdf7;
  box-shadow: 0 14rpx 28rpx rgba(31, 86, 76, 0.22);
}

.secondary-cta {
  border: 1rpx solid rgba(31, 86, 76, 0.7);
  background: rgba(255, 253, 247, 0.62);
  color: #1f564c;
  color: var(--travel-jade-deep);
}

.section-title {
  color: #22322d;
  color: var(--travel-ink);
  font-family: "STKaiti", "Kaiti SC", serif;
  font-size: 34rpx;
  font-weight: 700;
  line-height: 1.25;
}

.muted-text {
  color: #68736d;
  color: var(--travel-muted);
  font-size: 24rpx;
  line-height: 1.5;
}

.thin-divider {
  height: 1rpx;
  background: rgba(34, 50, 45, 0.1);
}
