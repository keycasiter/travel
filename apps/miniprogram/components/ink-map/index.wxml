<view class="ink-map">
  <view
    class="hero-map-stage"
    catchtouchstart="onMapTouchStart"
    catchtouchmove="onMapTouchMove"
    catchtouchend="onMapTouchEnd"
    catchtouchcancel="onMapTouchEnd"
  >
    <view
      class="hero-map-layer"
      style="transform: translate({{heroOffsetX}}rpx, {{heroOffsetY}}rpx) scale({{heroScale}});"
    >
      <image class="hero-map-image" src="{{heroImage}}" mode="aspectFill" />
      <button
        wx:for="{{cityHotspots}}"
        wx:key="id"
        class="city-hotspot {{selectedCityId === item.id ? 'city-hotspot-active' : ''}}"
        style="left: {{item.x}}%; top: {{item.y}}%;"
        data-id="{{item.id}}"
        catchtap="tapCityHotspot"
      >
        <view class="hotspot-dot"></view>
        <view class="hotspot-label">{{item.name}}</view>
      </button>
    </view>
  </view>

  <view wx:if="{{calibrationEnabled}}" class="calibration-overlay" catchtap="markCalibrationPoint">
    <view class="calibration-guide">点击地图取坐标</view>
    <view
      wx:if="{{calibrationPoint}}"
      class="calibration-cross"
      style="left: {{calibrationPoint.left}}; top: {{calibrationPoint.top}};"
    ></view>
    <button
      wx:if="{{calibrationPoint}}"
      class="calibration-copy"
      catchtap="copyCalibrationPoint"
    >{{calibrationPoint.snippet}}</button>
  </view>

  <view class="map-top">
    <view class="search-panel">
      <input
        class="search-input"
        value="{{searchKeyword}}"
        placeholder="搜索好玩的"
        confirm-type="search"
        bindinput="handleSearchInput"
        bindconfirm="submitSearch"
      />
    </view>
    <button class="locate-button" catchtap="locate">定位</button>
  </view>

  <view class="chips">
    <button
      wx:for="{{discoveryChips}}"
      wx:key="id"
      class="chip {{activeDiscoveryId === item.id ? 'chip-active' : ''}}"
      data-id="{{item.id}}"
      catchtap="tapDiscoveryChip"
    >{{item.label}}</button>
  </view>

  <view class="zoom-controls">
    <button class="map-control-button" aria-label="放大地图" data-delta="1" catchtap="zoomHeroMap">+</button>
    <button class="map-control-button" aria-label="缩小地图" data-delta="-1" catchtap="zoomHeroMap">-</button>
    <button class="map-control-button reset-control" aria-label="回到全国视角" catchtap="resetHeroMap">全</button>
  </view>
  <button
    wx:if="{{calibrationAvailable}}"
    class="calibration-toggle {{calibrationEnabled ? 'calibration-toggle-active' : ''}}"
    catchtap="toggleCalibrationMode"
  >标定</button>

  <view wx:if="{{selectedCityCard}}" class="city-card">
    <view class="city-card-header">
      <view>
        <view class="city-kicker">{{selectedCityCard.recommendedDays}} · {{selectedCityCard.activeDiscoveryLabel}}</view>
        <view class="city-title">{{selectedCityCard.name}}</view>
      </view>
      <view class="city-status-badge {{selectedCityCard.mvpReady ? 'city-status-ready' : ''}}">
        {{selectedCityCard.statusLabel}}
      </view>
      <button class="city-card-close" catchtap="closeCityCard">×</button>
    </view>
    <view class="city-mood">{{selectedCityCard.mood}}</view>
    <view class="city-summary">{{selectedCityCard.summary}}</view>
    <view class="city-note">{{selectedCityCard.activeDiscoveryNote}}</view>
    <view class="city-mvp-notice">{{selectedCityCard.mvpNotice}}</view>
    <view class="city-tags">
      <text wx:for="{{selectedCityCard.tags}}" wx:key="*this" class="city-tag">{{item}}</text>
    </view>
    <view class="card-actions">
      <button
        wx:if="{{selectedCityCard.mvpReady}}"
        class="action-button primary-action"
        data-id="{{selectedCityCard.id}}"
        catchtap="enterCityDetail"
      >看杭州内容</button>
      <button
        wx:if="{{selectedCityCard.mvpReady}}"
        class="action-button"
        data-id="{{selectedCityCard.id}}"
        catchtap="goPlan"
      >规划杭州行程</button>
      <button
        wx:else
        class="action-button pending-action"
        data-id="{{selectedCityCard.id}}"
        catchtap="enterCityDetail"
      >城市待完善</button>
    </view>
  </view>
</view>
