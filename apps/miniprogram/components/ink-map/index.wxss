.ink-map {
  position: relative;
  min-height: 100vh;
  overflow: hidden;
  background: #eef1ec;
}

.native-map {
  width: 100%;
  height: 100vh;
}

.map-top {
  position: absolute;
  top: 72rpx;
  left: 32rpx;
  right: 32rpx;
  display: flex;
  gap: 14rpx;
  align-items: center;
}

.search-input {
  flex: 1;
  height: 76rpx;
  box-sizing: border-box;
  padding: 0 28rpx;
  border: 1rpx solid rgba(34, 50, 45, 0.12);
  border-radius: 38rpx;
  background: rgba(255, 253, 248, 0.92);
  color: #5f6b65;
  font-size: 26rpx;
  line-height: 76rpx;
}

.locate-button {
  width: 116rpx;
  height: 76rpx;
  line-height: 76rpx;
  padding: 0;
  border-radius: 38rpx;
  background: #22322d;
  color: #fffdf8;
  font-size: 24rpx;
  margin: 0;
}

.chips {
  position: absolute;
  top: 162rpx;
  left: 32rpx;
  right: 32rpx;
  display: flex;
  gap: 12rpx;
  overflow-x: auto;
  white-space: nowrap;
}

.chip {
  flex: 0 0 auto;
  min-width: 96rpx;
  height: 58rpx;
  line-height: 56rpx;
  padding: 0 20rpx;
  border: 1rpx solid rgba(34, 50, 45, 0.12);
  border-radius: 28rpx;
  background: rgba(255, 253, 248, 0.86);
  color: #33443d;
  font-size: 24rpx;
  margin: 0;
  box-sizing: border-box;
}

.chip-active {
  background: #22564b;
  color: #fffdf8;
}

.zoom-controls {
  position: absolute;
  right: 32rpx;
  top: 250rpx;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.map-control-button {
  width: 68rpx;
  height: 68rpx;
  line-height: 66rpx;
  padding: 0;
  border: 1rpx solid rgba(34, 50, 45, 0.14);
  border-radius: 50%;
  background: rgba(255, 253, 248, 0.94);
  color: #22322d;
  font-size: 34rpx;
  font-weight: 700;
  box-shadow: 0 10rpx 28rpx rgba(34, 50, 45, 0.14);
}
