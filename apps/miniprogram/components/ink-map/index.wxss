.ink-map {
  position: relative;
  min-height: 100vh;
  overflow: hidden;
  background: #eef1ec;
}

.native-map {
  width: 100%;
  height: 100vh;
}

.map-top {
  position: absolute;
  top: 72rpx;
  left: 32rpx;
  right: 32rpx;
  z-index: 3;
  display: flex;
  gap: 14rpx;
  align-items: center;
}

.search-panel {
  position: relative;
  flex: 1;
  min-width: 0;
}

.search-input {
  width: 100%;
  height: 76rpx;
  box-sizing: border-box;
  padding: 0 28rpx;
  border: 1rpx solid rgba(34, 50, 45, 0.12);
  border-radius: 38rpx;
  background: rgba(255, 253, 248, 0.92);
  color: #5f6b65;
  font-size: 26rpx;
  line-height: 76rpx;
}

.search-suggestions {
  position: absolute;
  top: 88rpx;
  left: 0;
  right: 0;
  max-height: 360rpx;
  overflow: hidden;
  border: 1rpx solid rgba(34, 50, 45, 0.12);
  border-radius: 8rpx;
  background: rgba(255, 253, 248, 0.96);
  box-shadow: 0 16rpx 42rpx rgba(34, 50, 45, 0.16);
}

.suggestion-item {
  display: block;
  width: 100%;
  min-height: 84rpx;
  padding: 14rpx 24rpx;
  margin: 0;
  border-radius: 0;
  background: transparent;
  border-bottom: 1rpx solid rgba(34, 50, 45, 0.08);
  box-sizing: border-box;
  text-align: left;
}

.suggestion-item::after {
  border: 0;
}

.suggestion-title,
.suggestion-meta {
  display: block;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.suggestion-title {
  color: #22322d;
  font-size: 25rpx;
  line-height: 32rpx;
}

.suggestion-meta {
  margin-top: 4rpx;
  color: #66736d;
  font-size: 21rpx;
  line-height: 28rpx;
}

.locate-button {
  width: 116rpx;
  height: 76rpx;
  line-height: 76rpx;
  padding: 0;
  border-radius: 38rpx;
  background: #22322d;
  color: #fffdf8;
  font-size: 24rpx;
  margin: 0;
}

.chips {
  position: absolute;
  top: 162rpx;
  left: 32rpx;
  right: 32rpx;
  z-index: 2;
  display: flex;
  gap: 12rpx;
  overflow-x: auto;
  white-space: nowrap;
}

.chip {
  flex: 0 0 auto;
  min-width: 96rpx;
  height: 58rpx;
  line-height: 56rpx;
  padding: 0 20rpx;
  border: 1rpx solid rgba(34, 50, 45, 0.12);
  border-radius: 28rpx;
  background: rgba(255, 253, 248, 0.86);
  color: #33443d;
  font-size: 24rpx;
  margin: 0;
  box-sizing: border-box;
}

.chip-active {
  background: #22564b;
  color: #fffdf8;
}

.area-search-button {
  position: absolute;
  top: 232rpx;
  left: 50%;
  z-index: 2;
  width: 192rpx;
  height: 62rpx;
  line-height: 60rpx;
  padding: 0;
  margin: 0 0 0 -96rpx;
  border-radius: 31rpx;
  background: #22322d;
  color: #fffdf8;
  font-size: 24rpx;
  box-shadow: 0 12rpx 30rpx rgba(34, 50, 45, 0.2);
}

.zoom-controls {
  position: absolute;
  right: 32rpx;
  top: 250rpx;
  z-index: 2;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.map-control-button {
  width: 68rpx;
  height: 68rpx;
  line-height: 66rpx;
  padding: 0;
  border: 1rpx solid rgba(34, 50, 45, 0.14);
  border-radius: 50%;
  background: rgba(255, 253, 248, 0.94);
  color: #22322d;
  font-size: 34rpx;
  font-weight: 700;
  box-shadow: 0 10rpx 28rpx rgba(34, 50, 45, 0.14);
}

.explore-card {
  position: absolute;
  left: 32rpx;
  right: 32rpx;
  bottom: 34rpx;
  z-index: 3;
  box-sizing: border-box;
  padding: 24rpx;
  border: 1rpx solid rgba(34, 50, 45, 0.12);
  border-radius: 8rpx;
  background: rgba(255, 253, 248, 0.96);
  box-shadow: 0 18rpx 48rpx rgba(34, 50, 45, 0.18);
}

.card-header {
  display: flex;
  align-items: flex-start;
  gap: 18rpx;
}

.card-title {
  flex: 1;
  color: #22322d;
  font-size: 31rpx;
  font-weight: 700;
  line-height: 1.25;
}

.card-close {
  width: 48rpx;
  height: 48rpx;
  line-height: 44rpx;
  padding: 0;
  margin: 0;
  border-radius: 50%;
  background: rgba(34, 50, 45, 0.08);
  color: #22322d;
  font-size: 30rpx;
}

.card-meta,
.card-address,
.card-distance {
  margin-top: 8rpx;
  color: #64716b;
  font-size: 23rpx;
  line-height: 1.4;
}

.card-address {
  color: #45534d;
}

.route-strip {
  display: flex;
  gap: 10rpx;
  margin-top: 18rpx;
  overflow-x: auto;
  white-space: nowrap;
}

.route-chip {
  flex: 0 0 auto;
  min-width: 120rpx;
  height: 48rpx;
  line-height: 48rpx;
  padding: 0 16rpx;
  border-radius: 24rpx;
  background: #eef1ec;
  color: #33443d;
  font-size: 22rpx;
  text-align: center;
}

.card-actions {
  display: flex;
  gap: 12rpx;
  margin-top: 20rpx;
}

.action-button {
  flex: 1;
  height: 58rpx;
  line-height: 56rpx;
  padding: 0 8rpx;
  margin: 0;
  border-radius: 6rpx;
  background: #eef1ec;
  color: #22322d;
  font-size: 23rpx;
}

.primary-action {
  background: #22564b;
  color: #fffdf8;
}

.context-card {
  bottom: 34rpx;
}

.context-kicker {
  margin-bottom: 6rpx;
  color: #22564b;
  font-size: 22rpx;
  font-weight: 700;
}

.context-pois {
  display: flex;
  gap: 10rpx;
  margin-top: 16rpx;
  overflow-x: auto;
}

.context-poi {
  flex: 0 0 auto;
  max-width: 220rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  padding: 10rpx 14rpx;
  border-radius: 6rpx;
  background: #f4efe4;
  color: #33443d;
  font-size: 22rpx;
}
