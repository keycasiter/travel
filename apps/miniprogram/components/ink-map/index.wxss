.ink-map {
  position: relative;
  min-height: 100vh;
  overflow: hidden;
  background: #eef1ec;
}

.native-map {
  width: 100%;
  height: 100vh;
}

.map-top {
  position: absolute;
  top: 72rpx;
  left: 32rpx;
  right: 32rpx;
  z-index: 3;
  display: flex;
  gap: 14rpx;
  align-items: center;
}

.search-panel {
  position: relative;
  flex: 1;
  min-width: 0;
}

.search-input {
  width: 100%;
  height: 76rpx;
  box-sizing: border-box;
  padding: 0 28rpx;
  border: 1rpx solid rgba(34, 50, 45, 0.12);
  border-radius: 38rpx;
  background: rgba(255, 253, 248, 0.92);
  color: #5f6b65;
  font-size: 26rpx;
  line-height: 76rpx;
}

.search-suggestions {
  position: absolute;
  top: 88rpx;
  left: 0;
  right: 0;
  max-height: 360rpx;
  overflow: hidden;
  border: 1rpx solid rgba(34, 50, 45, 0.12);
  border-radius: 8rpx;
  background: rgba(255, 253, 248, 0.96);
  box-shadow: 0 16rpx 42rpx rgba(34, 50, 45, 0.16);
}

.suggestion-item {
  display: block;
  width: 100%;
  min-height: 84rpx;
  padding: 14rpx 24rpx;
  margin: 0;
  border-radius: 0;
  background: transparent;
  border-bottom: 1rpx solid rgba(34, 50, 45, 0.08);
  box-sizing: border-box;
  text-align: left;
}

.suggestion-item::after {
  border: 0;
}

.suggestion-title,
.suggestion-meta {
  display: block;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.suggestion-title {
  color: #22322d;
  font-size: 25rpx;
  line-height: 32rpx;
}

.suggestion-meta {
  margin-top: 4rpx;
  color: #66736d;
  font-size: 21rpx;
  line-height: 28rpx;
}

.locate-button {
  width: 116rpx;
  height: 76rpx;
  line-height: 76rpx;
  padding: 0;
  border-radius: 38rpx;
  background: #22322d;
  color: #fffdf8;
  font-size: 24rpx;
  margin: 0;
}

.chips {
  position: absolute;
  top: 162rpx;
  left: 32rpx;
  right: 32rpx;
  z-index: 2;
  display: flex;
  gap: 12rpx;
  overflow-x: auto;
  white-space: nowrap;
}

.chip {
  flex: 0 0 auto;
  min-width: 96rpx;
  height: 58rpx;
  line-height: 56rpx;
  padding: 0 20rpx;
  border: 1rpx solid rgba(34, 50, 45, 0.12);
  border-radius: 28rpx;
  background: rgba(255, 253, 248, 0.86);
  color: #33443d;
  font-size: 24rpx;
  margin: 0;
  box-sizing: border-box;
}

.chip-active {
  background: #22564b;
  color: #fffdf8;
}

.zoom-controls {
  position: absolute;
  right: 32rpx;
  top: 250rpx;
  z-index: 2;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.map-control-button {
  width: 68rpx;
  height: 68rpx;
  line-height: 66rpx;
  padding: 0;
  border: 1rpx solid rgba(34, 50, 45, 0.14);
  border-radius: 50%;
  background: rgba(255, 253, 248, 0.94);
  color: #22322d;
  font-size: 34rpx;
  font-weight: 700;
  box-shadow: 0 10rpx 28rpx rgba(34, 50, 45, 0.14);
}
