.ink-map {
  position: relative;
  min-height: 100vh;
  overflow: hidden;
  background: #e8e1d2;
  touch-action: none;
}

.hero-map-stage {
  position: absolute;
  inset: 0;
  overflow: hidden;
  background:
    radial-gradient(circle at 52% 45%, rgba(255, 253, 244, 0.34), rgba(217, 207, 187, 0.1) 38%, rgba(60, 79, 70, 0.2) 100%),
    #e8e1d2;
}

.hero-map-stage::after {
  position: absolute;
  inset: 0;
  pointer-events: none;
  content: '';
  background:
    linear-gradient(180deg, rgba(255, 252, 239, 0.2), rgba(32, 45, 40, 0.12)),
    radial-gradient(circle at 50% 12%, rgba(255, 255, 255, 0.3), rgba(255, 255, 255, 0) 42%);
}

.hero-map-layer {
  position: absolute;
  inset: 0;
  transform-origin: center center;
  transition: transform 180ms ease-out;
  will-change: transform;
}

.hero-map-image {
  width: 100%;
  height: 100%;
  display: block;
  opacity: 0.98;
}

.map-top {
  position: absolute;
  top: 72rpx;
  left: 32rpx;
  right: 32rpx;
  z-index: 5;
  display: flex;
  gap: 14rpx;
  align-items: center;
}

.search-panel {
  position: relative;
  flex: 1;
  min-width: 0;
}

.search-input {
  width: 100%;
  height: 76rpx;
  box-sizing: border-box;
  padding: 0 28rpx;
  border: 1rpx solid rgba(55, 67, 58, 0.14);
  border-radius: 38rpx;
  background: rgba(255, 253, 248, 0.88);
  color: #314039;
  font-size: 26rpx;
  line-height: 76rpx;
  box-shadow: 0 14rpx 34rpx rgba(38, 49, 43, 0.12);
  backdrop-filter: blur(12rpx);
}

.locate-button {
  width: 116rpx;
  height: 76rpx;
  line-height: 76rpx;
  padding: 0;
  border: 1rpx solid rgba(255, 253, 248, 0.36);
  border-radius: 38rpx;
  background: #273d36;
  color: #fffdf8;
  font-size: 24rpx;
  margin: 0;
  box-shadow: 0 14rpx 34rpx rgba(38, 49, 43, 0.18);
}

.chips {
  position: absolute;
  top: 162rpx;
  left: 32rpx;
  right: 32rpx;
  z-index: 4;
  display: flex;
  gap: 12rpx;
  overflow-x: auto;
  white-space: nowrap;
}

.chip {
  flex: 0 0 auto;
  min-width: 96rpx;
  height: 58rpx;
  line-height: 56rpx;
  padding: 0 20rpx;
  border: 1rpx solid rgba(55, 67, 58, 0.15);
  border-radius: 29rpx;
  background: rgba(255, 253, 248, 0.78);
  color: #314039;
  font-size: 24rpx;
  margin: 0;
  box-sizing: border-box;
  box-shadow: 0 10rpx 24rpx rgba(38, 49, 43, 0.08);
}

.chip-active {
  background: #8f2f22;
  border-color: rgba(143, 47, 34, 0.4);
  color: #fffdf8;
}

.city-hotspot {
  position: absolute;
  z-index: 3;
  width: 134rpx;
  height: 68rpx;
  padding: 0;
  margin: -34rpx 0 0 -67rpx;
  border: 0;
  border-radius: 34rpx;
  background: transparent;
  color: #4a2f22;
  line-height: 1;
  overflow: visible;
}

.city-hotspot::after {
  border: 0;
}

.hotspot-dot {
  position: absolute;
  left: 50%;
  top: 7rpx;
  width: 20rpx;
  height: 20rpx;
  margin-left: -10rpx;
  border: 3rpx solid rgba(255, 248, 219, 0.94);
  border-radius: 50%;
  background: #a43c2a;
  box-shadow:
    0 0 0 8rpx rgba(164, 60, 42, 0.16),
    0 10rpx 18rpx rgba(40, 31, 24, 0.18);
}

.hotspot-label {
  position: absolute;
  left: 50%;
  top: 34rpx;
  min-width: 64rpx;
  height: 32rpx;
  line-height: 32rpx;
  padding: 0 12rpx;
  transform: translateX(-50%);
  border: 1rpx solid rgba(122, 45, 34, 0.2);
  border-radius: 16rpx;
  background: rgba(255, 249, 233, 0.86);
  color: #5b3126;
  font-size: 21rpx;
  font-weight: 700;
  box-shadow: 0 8rpx 18rpx rgba(38, 49, 43, 0.12);
}

.city-hotspot-active .hotspot-dot {
  width: 26rpx;
  height: 26rpx;
  margin-left: -13rpx;
  background: #c89634;
  box-shadow:
    0 0 0 10rpx rgba(200, 150, 52, 0.18),
    0 0 28rpx rgba(200, 150, 52, 0.42);
}

.city-hotspot-active .hotspot-label {
  background: rgba(40, 61, 53, 0.94);
  border-color: rgba(40, 61, 53, 0.4);
  color: #fffdf8;
}

.zoom-controls {
  position: absolute;
  right: 32rpx;
  top: 250rpx;
  z-index: 4;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.map-control-button {
  width: 68rpx;
  height: 68rpx;
  line-height: 66rpx;
  padding: 0;
  border: 1rpx solid rgba(55, 67, 58, 0.14);
  border-radius: 50%;
  background: rgba(255, 253, 248, 0.88);
  color: #26312b;
  font-size: 34rpx;
  font-weight: 700;
  box-shadow: 0 10rpx 28rpx rgba(38, 49, 43, 0.14);
}

.reset-control {
  font-size: 24rpx;
}

.calibration-toggle {
  position: absolute;
  right: 32rpx;
  top: 484rpx;
  z-index: 7;
  width: 88rpx;
  height: 52rpx;
  line-height: 50rpx;
  padding: 0;
  margin: 0;
  border: 1rpx solid rgba(143, 47, 34, 0.24);
  border-radius: 6rpx;
  background: rgba(255, 253, 248, 0.9);
  color: #8f2f22;
  font-size: 22rpx;
  font-weight: 700;
  box-shadow: 0 10rpx 24rpx rgba(38, 49, 43, 0.12);
}

.calibration-toggle-active {
  background: #8f2f22;
  color: #fffdf8;
}

.calibration-overlay {
  position: absolute;
  inset: 0;
  z-index: 3;
  background:
    linear-gradient(rgba(143, 47, 34, 0.12) 1rpx, transparent 1rpx),
    linear-gradient(90deg, rgba(143, 47, 34, 0.12) 1rpx, transparent 1rpx);
  background-size: 10% 10%;
}

.calibration-guide {
  position: absolute;
  left: 32rpx;
  top: 238rpx;
  height: 48rpx;
  line-height: 48rpx;
  padding: 0 16rpx;
  border-radius: 6rpx;
  background: rgba(39, 61, 54, 0.88);
  color: #fffdf8;
  font-size: 22rpx;
}

.calibration-cross {
  position: absolute;
  width: 44rpx;
  height: 44rpx;
  margin: -22rpx 0 0 -22rpx;
  border: 2rpx solid #8f2f22;
  border-radius: 50%;
  background: rgba(255, 253, 248, 0.5);
  box-shadow: 0 0 0 8rpx rgba(143, 47, 34, 0.14);
}

.calibration-cross::before,
.calibration-cross::after {
  position: absolute;
  content: '';
  background: #8f2f22;
}

.calibration-cross::before {
  left: 50%;
  top: -18rpx;
  width: 2rpx;
  height: 80rpx;
}

.calibration-cross::after {
  left: -18rpx;
  top: 50%;
  width: 80rpx;
  height: 2rpx;
}

.calibration-copy {
  position: absolute;
  left: 50%;
  bottom: 248rpx;
  width: 220rpx;
  height: 56rpx;
  line-height: 54rpx;
  padding: 0;
  margin: 0 0 0 -110rpx;
  border-radius: 6rpx;
  background: #273d36;
  color: #fffdf8;
  font-size: 22rpx;
  box-shadow: 0 12rpx 28rpx rgba(38, 49, 43, 0.2);
}

.city-card {
  position: absolute;
  left: 32rpx;
  right: 32rpx;
  bottom: 34rpx;
  z-index: 6;
  box-sizing: border-box;
  padding: 26rpx;
  border: 1rpx solid rgba(76, 86, 74, 0.14);
  border-radius: 8rpx;
  background: rgba(255, 253, 248, 0.94);
  box-shadow: 0 18rpx 54rpx rgba(34, 48, 42, 0.22);
  backdrop-filter: blur(16rpx);
}

.city-card-header {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 14rpx;
}

.city-kicker {
  color: #8f2f22;
  font-size: 22rpx;
  font-weight: 700;
  line-height: 1.25;
}

.city-title {
  margin-top: 6rpx;
  color: #22322d;
  font-size: 38rpx;
  font-weight: 800;
  line-height: 1.2;
}

.city-status-badge {
  flex: 0 0 auto;
  height: 44rpx;
  padding: 0 14rpx;
  border: 1rpx solid rgba(143, 47, 34, 0.22);
  border-radius: 22rpx;
  background: rgba(143, 47, 34, 0.08);
  color: #8f2f22;
  font-size: 21rpx;
  font-weight: 700;
  line-height: 44rpx;
}

.city-status-ready {
  border-color: rgba(39, 61, 54, 0.26);
  background: #273d36;
  color: #fffdf8;
}

.city-card-close {
  width: 52rpx;
  height: 52rpx;
  line-height: 48rpx;
  padding: 0;
  margin: 0;
  border-radius: 50%;
  background: rgba(39, 61, 54, 0.09);
  color: #273d36;
  font-size: 30rpx;
}

.city-mood {
  margin-top: 14rpx;
  color: #314039;
  font-size: 26rpx;
  font-weight: 700;
  line-height: 1.35;
}

.city-summary,
.city-note {
  margin-top: 10rpx;
  color: #5f6c65;
  font-size: 24rpx;
  line-height: 1.48;
}

.city-note {
  padding: 14rpx 16rpx;
  border-left: 5rpx solid #8f2f22;
  border-radius: 6rpx;
  background: rgba(244, 238, 224, 0.72);
  color: #3c4c44;
}

.city-mvp-notice {
  margin-top: 12rpx;
  padding: 14rpx 16rpx;
  border-radius: 6rpx;
  background: rgba(200, 150, 52, 0.11);
  color: #7a5a26;
  font-size: 23rpx;
  line-height: 1.45;
}

.city-tags {
  display: flex;
  gap: 10rpx;
  margin-top: 16rpx;
  overflow-x: auto;
  white-space: nowrap;
}

.city-tag {
  flex: 0 0 auto;
  padding: 8rpx 14rpx;
  border-radius: 6rpx;
  background: rgba(39, 61, 54, 0.08);
  color: #314039;
  font-size: 22rpx;
}

.card-actions {
  display: flex;
  gap: 12rpx;
  margin-top: 20rpx;
}

.action-button {
  flex: 1;
  height: 66rpx;
  line-height: 64rpx;
  padding: 0 8rpx;
  margin: 0;
  border-radius: 6rpx;
  background: #eef1ec;
  color: #22322d;
  font-size: 24rpx;
}

.primary-action {
  background: #273d36;
  color: #fffdf8;
}

.pending-action {
  background: rgba(143, 47, 34, 0.09);
  color: #8f2f22;
}
