.page-title {
  padding-top: 40rpx;
}

.share-card {
  margin-top: 40rpx;
  padding: 28rpx;
  border: 1rpx solid rgba(34, 50, 45, 0.14);
  border-radius: 8rpx;
  background: #fffdf8;
}

.share-title,
.share-day-title {
  color: #22322d;
  font-size: 30rpx;
  font-weight: 700;
}

.share-day {
  margin-top: 24rpx;
}

.share-item {
  margin-top: 10rpx;
  color: #64716b;
  font-size: 24rpx;
}

.copy-button {
  margin-top: 28rpx;
  background: #22322d;
  color: #fffdf8;
}
