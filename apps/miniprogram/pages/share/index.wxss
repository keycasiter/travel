.share-page {
  padding-top: 70rpx;
  padding-bottom: 210rpx;
}

.share-nav {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
}

.readonly-pill {
  height: 44rpx;
  padding: 0 16rpx;
  border: 1rpx solid rgba(164, 123, 66, 0.55);
  border-radius: 22rpx;
  color: #8a672f;
  font-size: 22rpx;
  line-height: 44rpx;
}

.share-notice {
  display: flex;
  justify-content: space-between;
  gap: 18rpx;
  margin-top: 28rpx;
  padding: 18rpx 22rpx;
  border: 1rpx solid rgba(34, 50, 45, 0.1);
  border-radius: 12rpx;
  background: rgba(255, 253, 247, 0.68);
  color: #5e6963;
  font-size: 23rpx;
}

.share-notice view:first-child {
  flex: 1;
}

.share-notice view:last-child {
  flex: 0 0 auto;
  color: #8a672f;
}

.share-hero {
  display: flex;
  min-height: 286rpx;
  margin-top: 24rpx;
  overflow: hidden;
}

.share-hero-copy {
  z-index: 1;
  flex: 1;
  box-sizing: border-box;
  padding: 38rpx 0 34rpx 34rpx;
}

.share-title-row {
  display: flex;
  align-items: center;
  gap: 14rpx;
}

.share-title {
  max-width: 360rpx;
  color: #1f2e29;
  font-family: "STKaiti", "Kaiti SC", serif;
  font-size: 50rpx;
  font-weight: 700;
  line-height: 1.12;
}

.share-subtitle {
  margin-top: 16rpx;
  color: #3d4943;
  font-size: 27rpx;
}

.share-author {
  margin-top: 22rpx;
  color: #68736d;
  font-size: 22rpx;
}

.share-meta {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-top: 20rpx;
}

.share-meta view {
  height: 38rpx;
  padding: 0 12rpx;
  border-radius: 19rpx;
  background: rgba(232, 224, 209, 0.76);
  color: #657068;
  font-size: 20rpx;
  line-height: 38rpx;
}

.share-map {
  width: 284rpx;
  min-height: 286rpx;
  opacity: 0.92;
}

.share-card {
  margin-top: 24rpx;
  padding: 26rpx 24rpx 28rpx;
}

.share-tabs {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  overflow: hidden;
  border: 1rpx solid rgba(34, 50, 45, 0.1);
  border-radius: 12rpx;
}

.share-tab {
  position: relative;
  height: 76rpx;
  color: #5e6963;
  font-size: 26rpx;
  line-height: 76rpx;
  text-align: center;
}

.share-tab.active {
  background: linear-gradient(135deg, #2d6b5d, #1f564c);
  color: #fffdf7;
}

.share-timeline {
  margin-top: 28rpx;
}

.share-day {
  margin-top: 24rpx;
}

.share-day:first-child {
  margin-top: 0;
}

.share-day-title {
  color: #1f564c;
  font-size: 29rpx;
  font-weight: 700;
}

.share-item {
  display: grid;
  grid-template-columns: 26rpx 1fr 112rpx;
  gap: 16rpx;
  align-items: start;
  padding: 24rpx 0;
  border-bottom: 1rpx solid rgba(34, 50, 45, 0.08);
}

.share-dot {
  width: 18rpx;
  height: 18rpx;
  margin-top: 8rpx;
  border: 4rpx solid #a84a34;
  border-radius: 50%;
  background: #fffdf7;
}

.share-item-body {
  min-width: 0;
}

.share-item-title {
  overflow: hidden;
  color: #22322d;
  font-size: 29rpx;
  font-weight: 700;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.share-item-meta,
.share-item-note {
  margin-top: 8rpx;
  color: #68736d;
  font-size: 23rpx;
  line-height: 1.45;
}

.share-item-note {
  color: #9a6b2f;
}

.share-item-saved {
  height: 50rpx;
  border: 1rpx solid rgba(34, 50, 45, 0.16);
  border-radius: 8rpx;
  color: #526159;
  font-size: 21rpx;
  line-height: 50rpx;
  text-align: center;
}

.share-loading {
  margin-top: 28rpx;
  padding: 42rpx 32rpx;
}

.empty-title {
  color: #22322d;
  font-size: 32rpx;
  font-weight: 700;
}

.share-action-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 20;
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 18rpx;
  box-sizing: border-box;
  padding: 24rpx 28rpx 54rpx;
  border-top: 1rpx solid rgba(34, 50, 45, 0.1);
  background: rgba(255, 253, 247, 0.92);
}
