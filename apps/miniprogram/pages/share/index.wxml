<view class="page">
  <view class="page-title">分享行程</view>
  <view class="page-subtitle">{{status}} · 分享码：{{shareCode || '未提供'}}</view>
  <view wx:if="{{share}}" class="share-card">
    <view class="share-title">{{share.snapshot.title}}</view>
    <view wx:for="{{share.snapshot.days}}" wx:key="dayIndex" class="share-day">
      <view class="share-day-title">第 {{item.dayIndex}} 天 · {{item.summary}}</view>
      <view wx:for="{{item.items}}" wx:for-item="entry" wx:key="poiId" class="share-item">
        {{entry.startHint}} · {{entry.poiId}}
      </view>
    </view>
    <button class="copy-button" bindtap="copyShare">收藏为我的行程</button>
  </view>
</view>
