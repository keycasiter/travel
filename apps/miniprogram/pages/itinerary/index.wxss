.itinerary-page {
  padding-top: 62rpx;
}

.itinerary-nav {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 20rpx;
}

.nav-pill {
  height: 60rpx;
  padding: 0 22rpx;
  border: 1rpx solid rgba(34, 50, 45, 0.16);
  border-radius: 30rpx;
  background: rgba(255, 253, 247, 0.72);
  color: #22322d;
  font-size: 24rpx;
  line-height: 60rpx;
  white-space: nowrap;
}

.itinerary-hero {
  display: flex;
  min-height: 250rpx;
  margin-top: 28rpx;
  overflow: hidden;
}

.hero-copy {
  position: relative;
  z-index: 1;
  flex: 1;
  box-sizing: border-box;
  padding: 38rpx 0 34rpx 34rpx;
}

.hero-title-row {
  display: flex;
  align-items: center;
  gap: 14rpx;
}

.hero-title {
  font-family: "STKaiti", "Kaiti SC", serif;
  color: #1f2e29;
  font-size: 56rpx;
  font-weight: 700;
  line-height: 1;
}

.hero-subtitle {
  max-width: 340rpx;
  margin-top: 22rpx;
  color: #3d4943;
  font-size: 27rpx;
  line-height: 1.55;
}

.hero-meta {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-top: 24rpx;
}

.hero-meta view {
  height: 42rpx;
  padding: 0 14rpx;
  border-radius: 21rpx;
  background: rgba(232, 224, 209, 0.78);
  color: #526159;
  font-size: 21rpx;
  line-height: 42rpx;
}

.hero-map {
  width: 300rpx;
  min-height: 250rpx;
  opacity: 0.9;
}

.pending-place {
  margin-top: 24rpx;
  padding: 24rpx 28rpx;
  border-left: 6rpx solid #a84a34;
}

.pending-label {
  color: #a84a34;
  font-size: 22rpx;
  font-weight: 700;
}

.pending-title {
  margin-top: 8rpx;
  color: #22322d;
  font-size: 31rpx;
  font-weight: 700;
}

.pending-address {
  margin-top: 6rpx;
  color: #68736d;
  font-size: 23rpx;
  line-height: 1.45;
}

.planning-panel {
  margin-top: 26rpx;
  padding: 30rpx 28rpx;
}

.planning-step {
  display: flex;
  gap: 22rpx;
  padding: 24rpx 0;
}

.planning-step:first-child {
  padding-top: 0;
}

.step-index {
  width: 50rpx;
  height: 50rpx;
  flex: 0 0 50rpx;
  border-radius: 50%;
  background: #2d6b5d;
  color: #fffdf7;
  font-family: Georgia, serif;
  font-size: 28rpx;
  font-weight: 700;
  line-height: 50rpx;
  text-align: center;
}

.step-body {
  min-width: 0;
  flex: 1;
}

.step-title {
  margin-bottom: 18rpx;
  color: #22322d;
  font-family: "STKaiti", "Kaiti SC", serif;
  font-size: 34rpx;
  font-weight: 700;
}

.field-value,
.field-input {
  min-height: 76rpx;
  box-sizing: border-box;
  padding: 18rpx 22rpx;
  border: 1rpx solid rgba(34, 50, 45, 0.12);
  border-radius: 12rpx;
  background: rgba(248, 244, 236, 0.86);
  color: #22322d;
  font-size: 27rpx;
}

.days-control {
  display: grid;
  grid-template-columns: 1fr 156rpx 1fr;
  gap: 12rpx;
  align-items: center;
}

.days-chip {
  height: 74rpx;
  border: 1rpx solid rgba(34, 50, 45, 0.12);
  border-radius: 12rpx;
  background: rgba(255, 253, 247, 0.62);
  color: #526159;
  font-size: 24rpx;
  line-height: 74rpx;
  text-align: center;
}

.days-chip.muted {
  color: #8a8f88;
}

.days-input {
  min-height: 74rpx;
  text-align: center;
}

.preference-row {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-bottom: 14rpx;
}

.preference-chip {
  height: 60rpx;
  padding: 0 20rpx;
  border: 1rpx solid rgba(34, 50, 45, 0.12);
  border-radius: 30rpx;
  background: rgba(255, 253, 247, 0.72);
  color: #59645f;
  font-size: 23rpx;
  line-height: 60rpx;
}

.preference-chip.active {
  border-color: rgba(45, 107, 93, 0.55);
  color: #1f564c;
}

.preference-input {
  width: 100%;
}

.butler-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  margin-top: 26rpx;
  border: 1rpx solid rgba(34, 50, 45, 0.1);
  border-radius: 14rpx;
  overflow: hidden;
}

.butler-item {
  min-height: 108rpx;
  box-sizing: border-box;
  padding: 20rpx 12rpx;
  border-right: 1rpx solid rgba(34, 50, 45, 0.1);
  text-align: center;
}

.butler-item:last-child {
  border-right: 0;
}

.butler-label {
  color: #758078;
  font-size: 21rpx;
}

.butler-value {
  margin-top: 10rpx;
  color: #22322d;
  font-size: 26rpx;
  font-weight: 700;
}

.generate-button {
  width: 100%;
  margin-top: 28rpx;
}

.butler-panel,
.execution-panel {
  margin-top: 26rpx;
  padding: 30rpx 28rpx;
}

.weather-line {
  margin-top: 14rpx;
  color: #22322d;
  font-size: 28rpx;
}

.tip-row {
  margin-top: 14rpx;
  padding-top: 14rpx;
  border-top: 1rpx solid rgba(34, 50, 45, 0.08);
  color: #68736d;
  font-size: 24rpx;
  line-height: 1.5;
}

.execution-header {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 18rpx;
}

.share-button {
  width: 128rpx;
  height: 64rpx;
  line-height: 64rpx;
  font-size: 24rpx;
}

.day-block {
  margin-top: 30rpx;
}

.day-title {
  color: #1f564c;
  font-size: 28rpx;
  font-weight: 700;
}

.timeline-item {
  display: flex;
  gap: 18rpx;
  margin-top: 20rpx;
}

.timeline-rail {
  position: relative;
  width: 24rpx;
  flex: 0 0 24rpx;
}

.timeline-rail::after {
  content: "";
  position: absolute;
  top: 24rpx;
  left: 11rpx;
  width: 2rpx;
  height: calc(100% + 22rpx);
  background: rgba(45, 107, 93, 0.28);
}

.timeline-dot {
  position: relative;
  z-index: 1;
  width: 22rpx;
  height: 22rpx;
  border: 4rpx solid #a84a34;
  border-radius: 50%;
  background: #fffdf7;
}

.timeline-dot.done {
  border-color: #2d6b5d;
  background: #2d6b5d;
}

.timeline-content {
  flex: 1;
  min-width: 0;
  padding: 22rpx 0 24rpx;
  border-bottom: 1rpx solid rgba(34, 50, 45, 0.09);
}

.item-topline {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 14rpx;
}

.row-title {
  color: #22322d;
  font-size: 30rpx;
  font-weight: 700;
}

.done-state {
  height: 44rpx;
  padding: 0 14rpx;
  border: 1rpx solid rgba(34, 50, 45, 0.12);
  border-radius: 22rpx;
  color: #526159;
  font-size: 21rpx;
  line-height: 44rpx;
  white-space: nowrap;
}

.row-summary,
.item-note {
  margin-top: 10rpx;
  color: #68736d;
  font-size: 24rpx;
  line-height: 1.45;
}

.item-note {
  color: #9a6b2f;
}

.actions {
  display: flex;
  gap: 12rpx;
  margin-top: 16rpx;
}

.mini-action {
  min-width: 112rpx;
  height: 54rpx;
  line-height: 54rpx;
  padding: 0 18rpx;
  border-radius: 8rpx;
  background: rgba(255, 253, 247, 0.72);
  color: #1f564c;
  font-size: 22rpx;
}
