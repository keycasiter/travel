.panel,
.day-card {
  margin-top: 40rpx;
  padding: 28rpx;
  border: 1rpx solid rgba(34, 50, 45, 0.14);
  border-radius: 8rpx;
  background: #fffdf8;
}

.pending-place {
  margin-top: 28rpx;
  padding: 24rpx;
  border-left: 6rpx solid #22564b;
  border-radius: 8rpx;
  background: #eef1ec;
}

.pending-label {
  color: #22564b;
  font-size: 22rpx;
  font-weight: 700;
}

.pending-title {
  margin-top: 8rpx;
  color: #22322d;
  font-size: 30rpx;
  font-weight: 700;
}

.pending-address {
  margin-top: 6rpx;
  color: #64716b;
  font-size: 23rpx;
  line-height: 1.45;
}

.compact-panel {
  margin-top: 24rpx;
}

.field-label {
  margin: 24rpx 0 10rpx;
  color: #22564b;
  font-size: 24rpx;
  font-weight: 700;
}

.field-value,
.field-input {
  min-height: 76rpx;
  box-sizing: border-box;
  padding: 18rpx 20rpx;
  border-radius: 8rpx;
  background: #f4efe4;
  color: #64716b;
  font-size: 28rpx;
}

.primary-button,
.secondary-button {
  margin-top: 28rpx;
  background: #22322d;
  color: #fffdf8;
}

.secondary-button {
  background: #22564b;
}

.panel-title,
.day-title {
  color: #22322d;
  font-size: 30rpx;
  font-weight: 700;
}

.item-row {
  padding: 22rpx 0;
  border-bottom: 1rpx solid rgba(34, 50, 45, 0.08);
}

.row-title {
  color: #22322d;
  font-size: 28rpx;
  font-weight: 700;
}

.row-summary,
.item-note {
  margin-top: 8rpx;
  color: #64716b;
  font-size: 24rpx;
  line-height: 1.45;
}

.item-note {
  color: #9a6b2f;
}

.actions {
  display: flex;
  gap: 12rpx;
  margin-top: 14rpx;
}
