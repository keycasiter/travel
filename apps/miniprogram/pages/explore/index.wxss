.explore-page {
  padding: 0;
  position: relative;
  overflow: hidden;
}

.status-card {
  position: absolute;
  left: 32rpx;
  right: 32rpx;
  bottom: 250rpx;
  padding: 22rpx 26rpx;
  border: 1rpx solid rgba(34, 50, 45, 0.12);
  border-radius: 8rpx;
  background: rgba(255, 253, 248, 0.9);
  color: #4f5e57;
  font-size: 24rpx;
  line-height: 1.45;
}

.plan-button {
  position: fixed;
  right: 32rpx;
  bottom: 150rpx;
  height: 88rpx;
  padding: 0 34rpx;
  border-radius: 44rpx;
  background: #22322d;
  color: #fffdf8;
  font-size: 28rpx;
  box-shadow: 0 16rpx 40rpx rgba(34, 50, 45, 0.24);
}

.sheet-content {
  margin-top: 24rpx;
  padding-bottom: 30rpx;
}

.section-title {
  margin: 28rpx 0 14rpx;
  color: #22564b;
  font-size: 26rpx;
  font-weight: 700;
}

.content-row {
  padding: 20rpx 0;
  border-bottom: 1rpx solid rgba(34, 50, 45, 0.08);
}

.row-title {
  color: #22322d;
  font-size: 28rpx;
  font-weight: 700;
}

.row-summary {
  margin-top: 8rpx;
  color: #64716b;
  font-size: 24rpx;
  line-height: 1.45;
}
