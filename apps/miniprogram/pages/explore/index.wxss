.explore-page {
  padding: 0;
  position: relative;
  overflow: hidden;
}

.hero-map {
  min-height: 100vh;
  position: relative;
  background:
    radial-gradient(circle at 36% 24%, rgba(42, 88, 77, 0.45), transparent 20%),
    radial-gradient(circle at 70% 58%, rgba(188, 154, 86, 0.24), transparent 22%),
    linear-gradient(180deg, #fbf6e8, #e7dcc3);
}

.map-glow {
  position: absolute;
  left: 12%;
  right: 8%;
  top: 18%;
  height: 45vh;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.38);
  filter: blur(18rpx);
}

.china-shape {
  position: absolute;
  left: 50%;
  top: 42%;
  width: 520rpx;
  height: 380rpx;
  transform: translate(-50%, -50%) rotate(-8deg) skew(-12deg);
  border-radius: 45% 38% 34% 50%;
  background:
    radial-gradient(circle at 64% 34%, rgba(70, 115, 98, 0.55), transparent 20%),
    radial-gradient(circle at 34% 60%, rgba(30, 68, 61, 0.45), transparent 28%),
    linear-gradient(140deg, rgba(23, 75, 67, 0.92), rgba(146, 153, 128, 0.35));
  box-shadow: 0 70rpx 120rpx rgba(31, 54, 49, 0.26);
}

.hotspot {
  position: absolute;
  width: 24rpx;
  height: 24rpx;
  border-radius: 50%;
  border: 6rpx solid #fffdf8;
  background: #b9583d;
  box-shadow: 0 10rpx 28rpx rgba(0, 0, 0, 0.24);
}

.hotspot-hz {
  left: 56%;
  top: 43%;
}

.hotspot-bj {
  left: 49%;
  top: 33%;
}

.map-copy {
  position: absolute;
  left: 40rpx;
  right: 40rpx;
  top: 112rpx;
}

.plan-button {
  position: fixed;
  right: 32rpx;
  bottom: 150rpx;
  height: 88rpx;
  padding: 0 34rpx;
  border-radius: 44rpx;
  background: #22322d;
  color: #fffdf8;
  font-size: 28rpx;
  box-shadow: 0 16rpx 40rpx rgba(34, 50, 45, 0.24);
}
