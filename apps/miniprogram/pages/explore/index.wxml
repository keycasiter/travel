<view class="page explore-page">
  <view class="hero-map">
    <view class="map-glow"></view>
    <view class="china-shape"></view>
    <view class="hotspot hotspot-hz"></view>
    <view class="hotspot hotspot-bj"></view>
    <view class="map-copy">
