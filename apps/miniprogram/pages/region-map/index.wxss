.region-map-page {
  position: relative;
  width: 100vw;
  height: 100vh;
  overflow: hidden;
  background: #eef1ec;
}

.native-map {
  width: 100vw;
  height: 100vh;
}

.map-header {
  position: absolute;
  top: 64rpx;
  left: 28rpx;
  right: 28rpx;
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.back-button {
  width: 112rpx;
  height: 68rpx;
  line-height: 68rpx;
  padding: 0;
  border-radius: 34rpx;
  background: rgba(34, 50, 45, 0.9);
  color: #fffdf8;
  font-size: 24rpx;
}

.map-title {
  flex: 1;
  height: 68rpx;
  box-sizing: border-box;
  padding: 0 24rpx;
  border: 1rpx solid rgba(34, 50, 45, 0.12);
  border-radius: 34rpx;
  background: rgba(255, 253, 248, 0.92);
  color: #22322d;
  font-size: 26rpx;
  font-weight: 700;
  line-height: 68rpx;
}

.map-actions {
  position: absolute;
  right: 28rpx;
  top: 154rpx;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.action-button {
  width: 76rpx;
  height: 76rpx;
  line-height: 76rpx;
  padding: 0;
  border-radius: 50%;
  background: rgba(255, 253, 248, 0.94);
  color: #22322d;
  font-size: 22rpx;
  box-shadow: 0 10rpx 28rpx rgba(34, 50, 45, 0.14);
}

.poi-panel {
  position: absolute;
  left: 28rpx;
  right: 28rpx;
  bottom: 42rpx;
  box-sizing: border-box;
  padding: 24rpx;
  border: 1rpx solid rgba(34, 50, 45, 0.12);
  border-radius: 8rpx;
  background: rgba(255, 253, 248, 0.94);
  box-shadow: 0 18rpx 44rpx rgba(34, 50, 45, 0.16);
}

.status-text {
  color: #5f6b65;
  font-size: 23rpx;
}

.poi-title {
  margin-top: 10rpx;
  color: #22322d;
  font-size: 30rpx;
  font-weight: 700;
}

.poi-summary,
.transport-text {
  margin-top: 8rpx;
  color: #64716b;
  font-size: 24rpx;
  line-height: 1.45;
}

.traffic-button {
  margin-top: 18rpx;
  width: 100%;
  height: 72rpx;
  line-height: 72rpx;
  padding: 0;
  border-radius: 8rpx;
  background: #22564b;
  color: #fffdf8;
  font-size: 25rpx;
  font-weight: 700;
}
