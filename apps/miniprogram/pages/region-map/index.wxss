.region-map-page {
  position: relative;
  width: 100vw;
  height: 100vh;
  overflow: hidden;
  background: #eef1ec;
}

.native-map {
  width: 100vw;
  height: 100vh;
}

.map-header {
  position: absolute;
  top: 62rpx;
  left: 28rpx;
  right: 28rpx;
  z-index: 5;
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.back-button {
  width: 112rpx;
  height: 68rpx;
  line-height: 68rpx;
  padding: 0;
  border-radius: 34rpx;
  background: rgba(34, 50, 45, 0.9);
  color: #fffdf8;
  font-size: 24rpx;
}

.map-title {
  flex: 1;
  min-width: 0;
  height: 78rpx;
  box-sizing: border-box;
  padding: 10rpx 24rpx;
  border: 1rpx solid rgba(34, 50, 45, 0.12);
  border-radius: 39rpx;
  background: rgba(255, 253, 248, 0.92);
  box-shadow: 0 12rpx 28rpx rgba(34, 50, 45, 0.12);
}

.map-title-main {
  overflow: hidden;
  color: #22322d;
  font-size: 26rpx;
  font-weight: 700;
  line-height: 30rpx;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.map-title-sub {
  margin-top: 2rpx;
  color: #68736d;
  font-size: 20rpx;
  line-height: 22rpx;
}

.map-filter-chips {
  position: absolute;
  top: 156rpx;
  left: 28rpx;
  right: 116rpx;
  z-index: 5;
  display: flex;
  gap: 12rpx;
  overflow-x: auto;
  white-space: nowrap;
}

.filter-chip {
  flex: 0 0 auto;
  height: 64rpx;
  padding: 0 24rpx;
  border: 1rpx solid rgba(34, 50, 45, 0.13);
  border-radius: 32rpx;
  background: rgba(255, 253, 248, 0.92);
  color: #22322d;
  font-size: 24rpx;
  line-height: 64rpx;
  box-shadow: 0 10rpx 24rpx rgba(34, 50, 45, 0.1);
}

.filter-chip.active {
  border-color: rgba(45, 107, 93, 0.5);
  background: #2d6b5d;
  color: #fffdf8;
}

.map-actions {
  position: absolute;
  right: 28rpx;
  top: 248rpx;
  z-index: 5;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.action-button {
  width: 76rpx;
  height: 76rpx;
  line-height: 76rpx;
  padding: 0;
  border-radius: 50%;
  background: rgba(255, 253, 248, 0.94);
  color: #22322d;
  font-size: 22rpx;
  box-shadow: 0 10rpx 28rpx rgba(34, 50, 45, 0.14);
}

.poi-sheet {
  position: absolute;
  left: 24rpx;
  right: 24rpx;
  bottom: 36rpx;
  z-index: 6;
  box-sizing: border-box;
  padding: 18rpx 26rpx 24rpx;
  border: 1rpx solid rgba(34, 50, 45, 0.12);
  border-radius: 22rpx;
  background:
    linear-gradient(145deg, rgba(255, 253, 248, 0.96), rgba(246, 238, 224, 0.9));
  box-shadow: 0 18rpx 44rpx rgba(34, 50, 45, 0.18);
}

.sheet-grabber {
  width: 64rpx;
  height: 7rpx;
  margin: 0 auto 18rpx;
  border-radius: 7rpx;
  background: rgba(34, 50, 45, 0.18);
}

.status-text {
  color: #68736d;
  font-size: 23rpx;
}

.poi-title-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  margin-top: 10rpx;
}

.poi-title {
  min-width: 0;
  overflow: hidden;
  color: #22322d;
  font-family: "STKaiti", "Kaiti SC", serif;
  font-size: 38rpx;
  font-weight: 700;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.poi-type {
  flex: 0 0 auto;
  height: 42rpx;
  padding: 0 14rpx;
  border-radius: 21rpx;
  background: rgba(168, 74, 52, 0.12);
  color: #a84a34;
  font-size: 20rpx;
  line-height: 42rpx;
}

.poi-summary,
.transport-text {
  margin-top: 10rpx;
  color: #68736d;
  font-size: 24rpx;
  line-height: 1.45;
}

.transport-text {
  padding-top: 12rpx;
  border-top: 1rpx solid rgba(34, 50, 45, 0.08);
  color: #8a672f;
}

.poi-action-row {
  display: grid;
  grid-template-columns: 1fr 1fr 1fr;
  gap: 12rpx;
  margin-top: 20rpx;
}

.sheet-button {
  height: 72rpx;
  line-height: 72rpx;
  padding: 0;
  border-radius: 10rpx;
  font-size: 24rpx;
  font-weight: 700;
}

.sheet-button.secondary {
  border: 1rpx solid rgba(31, 86, 76, 0.58);
  background: rgba(255, 253, 248, 0.55);
  color: #1f564c;
}

.sheet-button.primary {
  background: linear-gradient(135deg, #2d6b5d, #1f564c);
  color: #fffdf8;
}
